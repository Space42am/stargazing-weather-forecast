{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run weather report",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\main.py",
            "python": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
            "console": "integratedTerminal",
            "env": {
                "PYTHONUTF8": "1"
            },
            "cwd": "${workspaceFolder}"
        }
    ]
}
